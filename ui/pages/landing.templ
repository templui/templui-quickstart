package pages

import (
	"github.com/templui/templui/components/button"
	"github.com/templui/templui/components/icon"
	"myapp/ui/layouts"
)

templ Landing() {
	@layouts.BaseLayout() {
		<div class="flex h-full items-center justify-center">
			<div class="flex w-full max-w-2xl flex-col items-center justify-center gap-4 px-4">
				<div class="space-y-4 text-center">
					<h1 class="text-5xl font-bold tracking-tight">templUI Quickstart</h1>
					<p class="text-muted-foreground mx-auto max-w-md text-lg">
						Build modern web applications with
						<br/>
						Go, templ, and Tailwind CSS.
					</p>
					<p class="text-muted-foreground mx-auto max-w-md text-sm">
						Need more? Check out
						<a href="https://pro.templui.io/" target="_blank" class="text-primary underline underline-offset-4 hover:opacity-80">templUI Pro</a>
						and
						<a href="https://goilerplate.com/" target="_blank" class="text-primary underline underline-offset-4 hover:opacity-80">goilerplate</a>.
					</p>
				</div>
				<div class="flex gap-3">
					@button.Button(button.Props{
						Variant: button.VariantDefault,
						Href:    "https://templui.io/docs/how-to-use",
						Target:  "_blank",
					}) {
						@icon.Book(icon.Props{Class: "size-4"})
						Documentation
					}
					@button.Button(button.Props{
						Variant: button.VariantOutline,
						Href:    "https://github.com/templui/templui",
						Target:  "_blank",
					}) {
						@icon.GitBranch(icon.Props{Class: "size-4"})
						GitHub
					}
				</div>
				<p class="text-muted-foreground text-sm">
					<a href="https://github.com/templui/templui/discussions" target="_blank" class="text-primary underline underline-offset-4 hover:opacity-80">Join the community</a>
				</p>
			</div>
		</div>
	}
}
